# ── PostgreSQL connection ──────────────────────────────────────
# Local development
DB_HOST=localhost
DB_PORT=5432
DB_NAME=disease_risk_db
DB_USER=postgres
DB_PASSWORD=your_password_here

# OR use a single connection string (takes precedence if set)
# DATABASE_URL=postgresql://user:password@host:5432/disease_risk_db

# ── Server ────────────────────────────────────────────────────
PORT=3001

# ── CORS — comma-separated list of allowed origins ───────────
# Set to your frontend URL in production
CORS_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,http://localhost:3000

# ── SSL (set to "true" in production / Railway / Render etc.) ─
DB_SSL=false
